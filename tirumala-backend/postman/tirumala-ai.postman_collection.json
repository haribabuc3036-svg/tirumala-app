        {
            "name": "Validation Errors",
            "description": "Requests with bad input that should return HTTP 400 without calling the AI.",
            "item": [
                {
                    "name": "Empty message — 400",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
