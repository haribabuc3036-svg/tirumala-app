                    }
                },
                {
                    "name": "Invalid history role — 400",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"message\": \"What is Vaikunta Ekadasi?\",\n    \"history\": [\n        {\n            \"role\": \"assistant\",\n            \"content\": \"Some prior reply\"\n        }\n    ]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
