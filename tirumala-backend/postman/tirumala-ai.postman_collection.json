                            "raw": "{\n    \"message\": \"{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}{{$randomLoremParagraph}}\",\n    \"history\": []\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/ai/chat",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "ai", "chat"]
                        },
                        "description": "Sends a message that exceeds the 2000 character limit using Postman lorem paragraph variables. Expected: HTTP 400 `{ success: false, error: 'Message is too long (max 2000 characters).' }`"
                    }
