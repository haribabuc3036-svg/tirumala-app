        {
            "name": "Multi-Turn Conversations",
            "description": "Tests that demonstrate context-aware multi-turn chat. Each request includes a `history` array with prior exchanges.",
            "item": [
                {
                    "name": "Follow-up on Sevas",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"message\": \"How many sevas can I book in a single visit and what documents do I need?\",\n    \"history\": [\n        {\n            \"role\": \"user\",\n            \"content\": \"What sevas are available at Tirumala?\"\n        },\n        {\n            \"role\": \"model\",\n            \"content\": \"Tirumala offers many Arjitam Sevas (paid sevas) such as Suprabhatam, Thomala Seva, Archana, Astadala Pada Padmaradhana, Sahasra Deepalankara Seva, Unjal Seva, and Kalyanotsavam, among others. These can be booked through the TTD e-seva portal.\"\n        }\n    ]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/ai/chat",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "ai", "chat"]
                        },
                        "description": "Multi-turn: Prior exchange was about available sevas. This follow-up asks about how many can be booked and required documents. The AI should answer in context."
                    }
                },
                {
                    "name": "Follow-up on Darshan types",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"message\": \"Which one of those is the fastest darshan type?\",\n    \"history\": [\n        {\n            \"role\": \"user\",\n            \"content\": \"What are the different types of darshan available at Tirumala?\"\n        },\n        {\n            \"role\": \"model\",\n            \"content\": \"Tirumala offers several darshan types: 1) Sarva Darshan (free, token-based, longest wait), 2) Special Entry Darshan (SED) at Rs.300 with a quota-based online booking, 3) Divya Darshan (free for pilgrims arriving on foot via Alipiri or Srivari Mettu), 4) VIP break darshan for dignitaries, and 5) NRI darshan for non-resident Indians.\"\n        }\n    ]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/ai/chat",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "ai", "chat"]
                        },
                        "description": "Multi-turn: Prior exchange covered darshan types. This follow-up asks which is fastest. The AI should recall context and answer appropriately."
                    }
                }
            ]
        },
