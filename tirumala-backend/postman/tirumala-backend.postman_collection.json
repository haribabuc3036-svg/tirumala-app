{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Tirumala Backend API",
    "description": "API collection for the Tirumala TTD backend service.\n\nSet the `baseUrl` variable to your running server (default: `http://localhost:3000`).\n\nRoutes:\n- `/health` — server health check\n- `/api/darshan` — TTD pilgrim stats (Supabase + Firebase)\n- `/api/ssd` — SSD Token / Free Tickets status (Supabase + Firebase)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns server status, service name, timestamp and current environment."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/health",
                  "host": ["{{baseUrl}}"],
                  "path": ["health"]
                }
              },
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"tirumala-backend\",\n  \"timestamp\": \"2026-02-26T10:00:00.000Z\",\n  \"env\": \"development\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Darshan Updates",
      "item": [
        {
          "name": "Get Paginated Darshan Updates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/darshan?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "darshan"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (1-indexed)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Records per page"
                }
              ]
            },
            "description": "Returns paginated darshan stats from Supabase.\n\n**Query params:**\n- `page` (default: 1)\n- `limit` (default: 10)"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/darshan?page=1&limit=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "darshan"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "10" }
                  ]
                }
              },
              "body": "{\n  \"success\": true,\n  \"page\": 1,\n  \"limit\": 10,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"date\": \"2026-02-26\",\n      \"pilgrims\": \"62,483\",\n      \"tonsures\": \"21,145\",\n      \"hundi\": \"₹4.2 Cr\",\n      \"waiting\": \"12H\",\n      \"darshan_time\": \"6H\",\n      \"created_at\": \"2026-02-26T00:00:00.000Z\"\n    }\n  ]\n}"
