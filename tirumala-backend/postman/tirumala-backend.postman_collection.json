          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/darshan/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "darshan", "all"]
            },
            "description": "Returns all records from Supabase without pagination. Useful for seeding or full data export."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/darshan/all",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "darshan", "all"]
                }
              },
              "body": "{\n  \"success\": true,\n  \"count\": 2,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"date\": \"2026-02-26\",\n      \"pilgrims\": \"62,483\",\n      \"tonsures\": \"21,145\",\n      \"hundi\": \"₹4.2 Cr\",\n      \"waiting\": \"12H\",\n      \"darshan_time\": \"6H\",\n      \"created_at\": \"2026-02-26T00:00:00.000Z\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Upsert Darshan Update",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-02-26\",\n  \"pilgrims\": \"62,483\",\n  \"tonsures\": \"21,145\",\n  \"hundi\": \"₹4.2 Cr\",\n  \"waiting\": \"12H\",\n  \"darshan_time\": \"6H\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/darshan",
              "host": ["{{baseUrl}}"],
              "path": ["api", "darshan"]
            },
            "description": "Upserts a darshan update record (conflicts on `date`).\n\nSimultaneously:\n1. Persists to **Supabase** `darshan_updates` table\n2. Pushes live pilgrim data to **Firebase RTDB** so all connected app clients update instantly\n\n**Body fields:**\n- `date` — YYYY-MM-DD format (unique key)\n- `pilgrims` — formatted pilgrim count string\n- `tonsures` — formatted tonsure count\n- `hundi` — formatted hundi collection amount\n- `waiting` — sarva darshan waiting time (e.g. \"12H\")\n- `darshan_time` — seva darshan wait time (e.g. \"6H\")"
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"date\": \"2026-02-26\",\n  \"pilgrims\": \"62,483\",\n  \"tonsures\": \"21,145\",\n  \"hundi\": \"₹4.2 Cr\",\n  \"waiting\": \"12H\",\n  \"darshan_time\": \"6H\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/darshan",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "darshan"]
                }
              },
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"date\": \"2026-02-26\",\n    \"pilgrims\": \"62,483\",\n    \"tonsures\": \"21,145\",\n    \"hundi\": \"₹4.2 Cr\",\n    \"waiting\": \"12H\",\n    \"darshan_time\": \"6H\",\n    \"created_at\": \"2026-02-26T10:00:00.000Z\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
