# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# A long random secret string used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
# How long tokens stay valid (default 7 days). Examples: 1d, 12h, 30d
JWT_EXPIRES_IN=7d

# ─── TTD Website Scraper ──────────────────────────────────────────────────────
# node-cron expression for how often to poll the Tirumala website (IST timezone)
# Examples: "*/5 * * * *" = every 5 min | "*/10 * * * *" = every 10 min
SCRAPE_SCHEDULE=*/5 * * * *

# ─── Supabase (PostgreSQL) ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct PostgreSQL connection (optional — for raw pg queries)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Found in: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ─── Cloudinary (Wallpapers) ─────────────────────────────────────────────────
# Found in: Cloudinary Dashboard → API Environment Variables
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# Optional folder path in your Cloudinary Media Library
CLOUDINARY_FOLDER=tirumala/wallpapers
# Optional folder path for place photos
CLOUDINARY_PLACES_FOLDER=tirumala/places
